            PROJECT_AWS_PLATFORM="ECS"
          elif grep -qE "AWS::Serverless::Api|AWS::Serverless::Function" "aws.cfn.app.yml";then
            PROJECT_AWS_PLATFORM="Serverless"
          else
            PROJECT_AWS_PLATFORM="Unknown"
          fi
          export json_string=$(jq -n \
          --arg pipeline_id $CI_PIPELINE_ID \
          --arg deployment_duration 0 \
          --arg project_id $CI_PROJECT_ID \
          --arg project_name "$CI_PROJECT_NAME" \
          --arg project_url "$CI_PROJECT_URL" \
          --arg group_id $GROUP_ID \
          --arg group_name "$GROUP_NAME" \
          --arg pipeline_url "$CI_PIPELINE_URL" \
          --arg pipeline_type "$PIPELINE_TYPE" \
          --arg project_type "Standard" \
          --arg project_runtime "${PROJECT_RUNTIME}" \
          --arg project_aws_platform "${PROJECT_AWS_PLATFORM}" \
          --argjson job "$JOB_DETAILS" \
          '{
              "pipeline_id": $pipeline_id,
              "deployment_duration": $deployment_duration,
              "project_id": $project_id,
              "project_name": $project_name,
              "project_url": $project_url,
              "group_id": $group_id,
              "group_name": $group_name,
              "pipeline_url": $pipeline_url,
              "pipeline_type": $pipeline_type,
              "project_type": $project_type,
              "project_runtime": $project_runtime,
              "project_platform": $project_aws_platform,
              "job": $job
          }')

          curl -X POST https://$PULSE_DASHBOARD_WEBHOOK_URL \
            -H  "Content-Type: application/json" \
            -d "$json_string" || true
        else
          echo "Pulse dahsboard webhook URL has not be set" && exit 0
        fi
