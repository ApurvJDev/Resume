  .gitlab-badge: &snippet_gitlab_badge
    - "# --- Setting up gitlab badge -----------------------------------------"
    - |
      set +e  # don't exit on error if curl request fails
      if [[ ${CI_JOB_STAGE} == "int" ]]; then
        BADGE_NAME=projectType
        BADGE_EXISTS=$(curl -s --header "PRIVATE-TOKEN: $BOT_GITLAB_TOKEN" "$CI_API_V4_URL/projects/$CI_PROJECT_ID/badges" | jq --arg BADGE_NAME "$BADGE_NAME" -r '.[] | select(.name == $BADGE_NAME)')
        if [[ ! -n "$BADGE_EXISTS" ]]; then
          curl -sSf --request POST "${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/badges" --header "PRIVATE-TOKEN:${BOT_GITLAB_TOKEN}" \
            --data "link_url=https://gitlab.connectwisedev.com/${CI_PROJECT_PATH}" \
            --data "image_url=https://img.shields.io/badge/Project_Type-Self--Service-2CA5E0%26logo%3DProjectSelf%26logoColor%3Dwhite" \
            --data "kind=project" \
            --data "name=projectType" > /dev/null 2>&1 || true
        fi
      fi
    - |
      set +e  # don't exit on error if curl request fails
      # to check sonar and quality badge exist or not, if not then will create it
      if [[ ${CI_JOB_STAGE} == "test"  && ( ${CI_JOB_NAME} == "test:coverage-sonar"* ) ]]; then
        TOKEN=$(curl -su ${SONAR_TOKEN}: -X GET "$TOOLING_SONAR_HOST/api/project_badges/token?project=${CI_PROJECT_NAME}" | jq -r .token)
        if [[ $TOKEN ]]; then
          # Badges array to be defined with badge_name:metric
          BADGES=("qualitygate:alert_status" "sonarcoverage:coverage")
          # Creates a badge if it doesn't exist
          function create_badge {
            local BADGE_NAME="$1"
            local BADGE_METRIC="$2"
            GET_BADGE="${SONAR_HOST_URL}/api/project_badges/measure?project=${CI_PROJECT_NAME}&metric=${BADGE_METRIC}&token=${TOKEN}"
            curl -sSf --request POST "${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/badges" --header "PRIVATE-TOKEN:${BOT_GITLAB_TOKEN}" \
              --data "link_url=https://gitlab.connectwisedev.com/${CI_PROJECT_PATH}" \
              --data-urlencode "image_url=$GET_BADGE" \
              --data "kind=project" \
              --data "name=$BADGE_NAME" > /dev/null 2>&1 || true
          }
          # Iterate through badges array
          for BADGE_INFO in "${BADGES[@]}"; do
            IFS=":" read -r BADGE_NAME BADGE_METRIC <<< "$BADGE_INFO"
            # Checks if the badges exist
            BADGE_EXISTS=$(curl -s --header "PRIVATE-TOKEN: $BOT_GITLAB_TOKEN" "$CI_API_V4_URL/projects/$CI_PROJECT_ID/badges" | jq --arg BADGE_NAME "$BADGE_NAME" -r '.[] | select(.name == $BADGE_NAME)')
            if [[ ! -n "$BADGE_EXISTS" ]]; then
              create_badge "$BADGE_NAME" "$BADGE_METRIC"
            fi
          done
        fi
      fi
    - ""

