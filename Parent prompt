.fn:set-task-count: &snippet_set_task_count
  - |
    function set_task_count {
      local STACK_NAME=${1}
      local STACK_ENV=$(echo ${CI_JOB_NAME} | sed -E 's/^([a-zA-Z\-]+)(\:.+)*/\1/g')
      STACK_EXISTS_CHECK=$(aws cloudformation describe-stacks --stack-name "${STACK_NAME}" --query "Stacks[0].StackName" --output text 2>&1 || true)
      if [[ "${STACK_EXISTS_CHECK}" != "${STACK_NAME}" ]]; then
        echo "stack does not exist: ${STACK_NAME}"
        return 0
      fi
      ECS_SERVICES=$(aws cloudformation describe-stack-resources --stack-name "${STACK_NAME}" --query "StackResources[?ResourceType=='AWS::ECS::Service'].PhysicalResourceId" --output text)
      for SERVICE_ID in ${ECS_SERVICES}; do
        [[ -z ${SERVICE_ID} ]] && continue
        echo "Updating the number of containers for service: ${SERVICE_ID}"
        CLUSTER_NAME=$(echo "${SERVICE_ID}" | awk -F'/' '{print $2}')
        SERVICE_NAME=$(echo "${SERVICE_ID}" | awk -F'/' '{print $3}')
        aws application-autoscaling register-scalable-target --service-namespace "ecs" --scalable-dimension "ecs:service:DesiredCount" --resource-id "service/${CLUSTER_NAME}/${SERVICE_NAME}" --min-capacity "1" --max-capacity "1"
        aws ecs update-service --cluster "${CLUSTER_NAME}" --service "${SERVICE_NAME}" --desired-count "1" --query "service.[serviceArn,deployments[].desiredCount]"
      done
    }
  - export -f set_task_count

