    - ""
    - "# --- test coverage ---------------------------------------------------"
    - git fetch --tags
    - |
      if [[ $JOB_COVERAGE_THRESHOLD == 0 ]]; then
        echo "skipped: coverage threshold is 0"
      elif [[ -z $JOB_COVERAGE_VALUE || $JOB_COVERAGE_VALUE = "null" ]]; then
        echo "failed: unable to retrieve test coverage percentage; ensure test coverage parsing is defined in project's ci settings"
        exit 1
      elif [[ $(echo "$JOB_COVERAGE_VALUE >= $JOB_COVERAGE_THRESHOLD" | bc -q) -eq 1 ]]; then
        echo "success: $JOB_COVERAGE_VALUE above the min coverage threshold of $JOB_COVERAGE_THRESHOLD"
      else
        echo "failed: $JOB_COVERAGE_VALUE below the min coverage threshold of $JOB_COVERAGE_THRESHOLD"
        exit 1
      fi

.job-test-coverage-sonar:
  image: sonarsource/sonar-scanner-cli:4.8.0
  variables:
    SONAR_HOST_URL: $TOOLING_SONAR_HOST
    SONAR_TOKEN: $TOOLING_SONAR_TOKEN
    SONAR_USER_HOME: "${CI_PROJECT_DIR}/.sonar"
    GIT_DEPTH: "0"
  cache:
    key: "${CI_JOB_NAME}"
    paths:
      - .sonar/cache
  script:
    - *snippet_print_ci_vars
    - "# --- install dependencies --------------------------------------------"
    - apk --no-cache add gettext jq
    - "# --- test coverage ---------------------------------------------------"
    - cat sonar-project.properties | envsubst > /tmp/sonar-project.properties
    - mv /tmp/sonar-project.properties sonar-project.properties
    - |
      if [[ ! -z $CI_MERGE_REQUEST_TARGET_BRANCH_NAME ]];then
        sonar-scanner \
          -Dsonar.qualitygate.wait=true \
          -Dsonar.scanner.metadataFilePath=${SONAR_USER_HOME}/report-task.txt \
          -Dsonar.pullrequest.branch=$CI_MERGE_REQUEST_SOURCE_BRANCH_NAME \
          -Dsonar.pullrequest.base=$CI_MERGE_REQUEST_TARGET_BRANCH_NAME \
          -Dsonar.pullrequest.key=$CI_MERGE_REQUEST_IID \
          -Dsonar.pullrequest.gitlab.repositorySlug=$CI_PROJECT_ID
      else
        sonar-scanner \
          -Dsonar.qualitygate.wait=true \
          -Dsonar.scanner.metadataFilePath=${SONAR_USER_HOME}/report-task.txt \
          -Dsonar.branch.name=$CI_COMMIT_REF_SLUG
      fi
    - CE_TASK_ID="$(cat .sonar/report-task.txt | grep ceTaskId | cut -d '=' -f2)"
    - wait_for_success=true
    - |
      while [[ "${wait_for_success}" == "true" ]]
      do
        CE_STATUS="$(curl -su ${SONAR_TOKEN}: "${SONAR_HOST_URL}/api/ce/task?id=${CE_TASK_ID}" | jq -r .task.status)"
        echo "SonarQube job status : ${CE_STATUS}"
        if [[ "${CE_STATUS}" == "CANCELLED" || "${CE_STATUS}" == "FAILED" ]];then
          echo "failed: SonarQube job status is ${CE_STATUS}" && exit 1
        fi
        if [[ "${CE_STATUS}" == "SUCCESS" ]];then
          wait_for_success=false
        fi
        sleep 5
      done
    - >-
      export ANALYSIS_ID="$(curl -su ${SONAR_TOKEN}: "${SONAR_HOST_URL}/api/ce/task?id=${CE_TASK_ID}" | jq -r .task.analysisId)"
    - >-
      export TASK_STATUS="$(curl -su ${SONAR_TOKEN}: "${SONAR_HOST_URL}/api/qualitygates/project_status?analysisId=${ANALYSIS_ID}" | jq -r .projectStatus.status)"
    - |
      if [[ "${TASK_STATUS}" == "OK" ]];then
