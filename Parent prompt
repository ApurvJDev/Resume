.fn:sam-deploy: &snippet_fn_sam_deploy
  - |
    function sam_deploy {
      local STACK_NAME=${1}
      local STACK_TEMPLATE=${2}
      local STACK_TIER=$(echo ${STACK_NAME} | sed -E 's/\w+-\w+-(\w+)/\1/g')
      local STACK_ENV=$(echo ${CI_JOB_NAME} | sed -E 's/^([a-zA-Z]+)(\:.+)*/\1/g')
      if [[ "${STACK_RESOURCE_DELETION_POLICY}" == "DISABLED" ]]; then
        sed -i "/DeletionPolicy\:\ /d"  ${STACK_TEMPLATE}
        sed -i "/DeletionProtection\:\ /d" ${STACK_TEMPLATE}
        sed -i "/UpdateReplacePolicy\:\ /d" ${STACK_TEMPLATE}
      fi
      if [[ -z "${STACK_ENV_TYPE}" ]]; then
        STACK_ENV_TYPE=$(( [[ "${CI_JOB_NAME}" =~ ^(inf|int|qa|perf|stg|prd).*$ ]] && echo "${CI_JOB_NAME}" | sed -E 's/^([a-zA-Z]+)(\:.+)*/\1/g' ) || ( [[ "${CI_JOB_NAME}" =~ ^(vendorintprod).*$ ]] && echo "prd" ) || echo "dev");
      fi
      export JOB_ECR_REPO=$(aws ssm get-parameter --name /$CORE_STACK_NAME/resources/ecr/repository/$JOB_DOCKER_IMAGE_NAME/full-name --query 'Parameter.Value' --output text)
      if [[ ! -z "${JOB_ECR_REPO}" ]]; then
        local IMAGE_REPO="--image-repository ${JOB_ECR_REPO}"
      else
        local IMAGE_REPO=""
      fi
      export SAM_CLI_TELEMETRY=0
      sam deploy --stack-name ${STACK_NAME} --template-file ${STACK_TEMPLATE} ${IMAGE_REPO} \
        --parameter-overrides \
          StackEnv=${STACK_ENV} \
          StackJobName=${STACK_JOB_ENV} \
          StackTier=${STACK_TIER} \
          StackType=${ACCOUNT_LEVEL} \
          StackVersion=${STACK_VERSION_RELEASE} \
          StackVersionSha=${CI_COMMIT_SHA} \
          StackVersionType=${STACK_TARGETED_VERSION} \
          ${@:3} \
        --tags \
          service_name=${STACK_SERVICE_NAME} \
          service_env=${STACK_ENV} \
          service_tier=${STACK_TIER} \
          service_version=${STACK_VERSION_RELEASE} \
          territory=${BILLING_TAG_TERRITORY} \
          region=${AWS_DEFAULT_REGION} \
          business_unit=${BILLING_TAG_BUSINESS_UNIT} \
          department=${BILLING_TAG_DEPARTMENT} \
          product=${BILLING_TAG_PRODUCT} \
          class=${BILLING_TAG_CLASS} \
          subclass=${ACCOUNT_TYPE} \
          ci:job:id=${CI_JOB_ID} \
          ci:pipeline:id=${CI_PIPELINE_IID}.${CI_PIPELINE_ID} \
          scm:project:branch=${CI_COMMIT_REF_SLUG} \
          scm:project:url=${CI_PROJECT_URL} \
          scm:project:id=${CI_PROJECT_ID}
    }
  - export -f sam_deploy

.fn:cfn-cleanup: &snippet_fn_cfn_cleanup
  - |
    function cfn_cleanup {
      local STACK_NAME=${1}
      local DELETE_STACK=${2:-$JOB_DELETE_STACK}

      if [[ "${STACK_RESOURCE_DELETION_POLICY}" == "DISABLED" ]]; then
        STACK_S3_BUCKETS=$(aws cloudformation describe-stack-resources --stack-name "${STACK_NAME}" --query "StackResources[?ResourceType=='AWS::S3::Bucket'].PhysicalResourceId" --output text)
        for BUCKET_NAME in ${STACK_S3_BUCKETS}; do
          [[ -z ${BUCKET_NAME} ]] && continue
          echo "deleting all objects in bucket: ${BUCKET_NAME}"
          aws s3 rm "s3://${BUCKET_NAME}" --recursive
        done

        STACK_VPC_EP_SVCS=$(aws cloudformation describe-stack-resources --stack-name "${STACK_NAME}" --query "StackResources[?ResourceType=='AWS::EC2::VPCEndpointService'].PhysicalResourceId" --output text)
        for VPC_EP_SVC in ${STACK_VPC_EP_SVCS}; do
          [[ -z ${VPC_EP_SVC} ]] && continue
          echo "rejecting all vpc endpoint connections: ${VPC_EP_SVC}"
          VPC_EP_SVC_CONNECTIONS=$(aws ec2 describe-vpc-endpoint-connections --filters Name=service-id,Values="${VPC_EP_SVC}" --query "VpcEndpointConnections[*].VpcEndpointId" --output text)
          for VPC_EP_SVC_CONNECTION in ${VPC_EP_SVC_CONNECTIONS}; do
            [[ -z ${VPC_EP_SVC_CONNECTION} ]] && continue
            aws ec2 reject-vpc-endpoint-connections --service-id "${VPC_EP_SVC}" --vpc-endpoint-ids "${VPC_EP_SVC_CONNECTION}"
          done
        done
      fi

      if [[ "${DELETE_STACK}" == "1" ]]; then
        STACK_ID=$(aws cloudformation describe-stacks --stack-name "${STACK_NAME}" --query 'Stacks[0].StackId' --output text 2>/dev/null)
        if [[ -n "${STACK_ID}" ]]; then
          aws cloudformation update-termination-protection --stack-name "${STACK_NAME}" --no-enable-termination-protection
          aws cloudformation delete-stack --stack-name "${STACK_NAME}"
          aws cloudformation wait stack-delete-complete --stack-name "${STACK_ID}"
        fi
      fi
    }
  - export -f cfn_cleanup

.fn:pull-release-image: &snippet_fn_pull_release_image
