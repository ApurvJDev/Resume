.fn:run-pipeline-job: &snippet_run_pipeline_job
  - |
    function run_pipeline_job {
      local JOB_NAME=${1}
      JOB_ID=$(
        curl -s -X GET --header "PRIVATE-TOKEN: ${BOT_GITLAB_TOKEN}" \
          ${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/pipelines/${CI_PIPELINE_ID}/jobs \
        | jq -c 'map ( select(.name=='\"${JOB_NAME}\"') )[0] | .id' \
      )
      if [[ -z "${JOB_ID}" || "${JOB_ID}" == "null" ]]; then
        echo "job to retry is not found: ${JOB_NAME}"
        return 0
      fi
      JOB_STATUS=$(
        curl -s -X GET --header "PRIVATE-TOKEN: ${BOT_GITLAB_TOKEN}" \
          ${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/jobs/${JOB_ID} | jq -r -c '.status'
      )
      if [[ "${JOB_STATUS}" == "manual" ]]; then
        curl -s -X POST --header "PRIVATE-TOKEN: ${BOT_GITLAB_TOKEN}" \
          ${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/jobs/${JOB_ID}/play
      elif [[ "${JOB_STATUS}" =~ ^failed|canceled|success$ ]]; then
        curl -s -X POST --header "PRIVATE-TOKEN: ${BOT_GITLAB_TOKEN}" \
          ${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/jobs/${JOB_ID}/retry
      elif [[ "${JOB_STATUS}" =~ ^running|started|pending$ ]]; then
        echo "deploy job is in a running state"
      else
        echo "unknown job state: ${JOB_STATUS}"
      fi
    }
  - export -f run_pipeline_job

