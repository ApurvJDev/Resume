      fi

      local SRC_ECR_REPO=$(aws ssm get-parameter --name /${CORE_STACK_NAME}/resources/ecr/repository/${IMG_NAME}/full-name --query 'Parameter.Value' --output text --region ${ARTIFACT_AWS_DEFAULT_REGION:-us-east-1})
