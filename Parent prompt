      local ASSUME_ROLE_ARN=${1}
      local SSM_PARAMETER_NAME=${2}

      ORIGINAL_AWS_ACCESS_KEY_ID=$AWS_ACCESS_KEY_ID
      ORIGINAL_AWS_SECRET_ACCESS_KEY=$AWS_SECRET_ACCESS_KEY

      assume_role_object=$(aws sts assume-role --role-arn "${ASSUME_ROLE_ARN}" --role-session-name fetch-ssm-param --duration-seconds 900)

      export AWS_ACCESS_KEY_ID=$(echo $assume_role_object | jq -r .'Credentials.AccessKeyId')
      export AWS_SECRET_ACCESS_KEY=$(echo $assume_role_object | jq -r .'Credentials.SecretAccessKey')
      export AWS_SESSION_TOKEN=$(echo $assume_role_object | jq -r .'Credentials.SessionToken')

      aws ssm get-parameter --name "${SSM_PARAMETER_NAME}" --query 'Parameter.Value' --output text --region "${AWS_DEFAULT_REGION}"

      export AWS_ACCESS_KEY_ID=$ORIGINAL_AWS_ACCESS_KEY_ID
      export AWS_SECRET_ACCESS_KEY=$ORIGINAL_AWS_SECRET_ACCESS_KEY
      export AWS_SESSION_TOKEN=""
