  .set-shared-vars: &snippet_set_shared_vars
    - "# --- determine build version ------------------------------------------"
    - |
      set +e  # don't exit on error while trying to set version
      versionFile=""
      projectVersion=""
      for vf in ".version" "pyproject.toml" "setup.py" "setup.cfg"; do
        if [[ -f "$vf" ]]; then
          if [ "$vf" == ".version" ]; then
            projectVersion=$(head -1 $vf | xargs)
          else
            projectVersion=$(grep -s 'version' "$vf" | cut -d'"' -f2)
          fi
          versionFile=$vf
          break
        fi
      done

      if [[ -z "$versionFile" || -z "$projectVersion" ]]; then
        # check in __init__.py as a last resort
        versionFile=$(grep -srl "__version__" src/**/__init__.py | head -1)
        projectVersion=$(grep -srni "__version__" "$versionFile" | cut -d'"' -f2)
        [[ -z "$versionFile" || -z "$projectVersion" ]] && echo "Could not locate version file for project"
      fi
      echo "VERSION FILE: $versionFile"
      echo "PROJECT VERSION: $projectVersion"

      export STACK_VERSION_FILE="$versionFile"
      export STACK_VERSION_RELEASE="$projectVersion"
      export STACK_VERSION_BUILD=$(semver bump build $CI_PIPELINE_IID $STACK_VERSION_RELEASE)
      set -e  # turn errors back on
    - ""
