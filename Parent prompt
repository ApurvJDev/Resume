.fn:cfn-deploy: &snippet_fn_cfn_deploy
  - |
    function cfn_deploy {
      local STACK_NAME=${1}
      local STACK_TEMPLATE=${2}
      local S3_STACK_TEMPLATE="aws.cfn.app.output.yml"
      local STACK_TIER=$(echo ${STACK_NAME} | sed -E 's/\w+-\w+-(\w+)/\1/g')
      local STACK_ENV=$(echo ${CI_JOB_NAME} | sed -E 's/^([a-zA-Z\-]+)(\:.+)*/\1/g')
      if [[ "${STACK_RESOURCE_DELETION_POLICY}" == "DISABLED" ]]; then
        sed -i "/DeletionPolicy\:\ /d"  ${STACK_TEMPLATE}
        sed -i "/DeletionProtection\:\ /d" ${STACK_TEMPLATE}
        sed -i "/UpdateReplacePolicy\:\ /d" ${STACK_TEMPLATE}
      fi
      if [[ -z "${STACK_ENV_TYPE}" ]]; then
        STACK_ENV_TYPE=$(( [[ "${CI_JOB_NAME}" =~ ^(inf|int|qa|perf|stg|prd).*$ ]] && echo "${CI_JOB_NAME}" | sed -E 's/^([a-zA-Z]+)(\:.+)*/\1/g' ) || ( [[ "${CI_JOB_NAME}" =~ ^(vendorintprod).*$ ]] && echo "prd" ) || echo "dev");
      fi
      local TEMPLATE_SIZE=$(find . -name "$STACK_TEMPLATE" -exec stat -c %s {} \;)
      if [[ $TEMPLATE_SIZE -le 51200 ]]; then
        local TEMPLATE_PATH="--template-file $STACK_TEMPLATE"
      else
        local S3_PREFIX="cfn/$CI_COMMIT_SHA/$S3_STACK_TEMPLATE"
        aws cloudformation package --template-file "${STACK_TEMPLATE}" --s3-bucket ${CORE_STACK_ARTIFACT_S3_BUCKET} --s3-prefix ${S3_PREFIX} --output-template-file ${S3_STACK_TEMPLATE}
        local TEMPLATE_PATH="--template-file $S3_STACK_TEMPLATE --s3-bucket $CORE_STACK_ARTIFACT_S3_BUCKET --s3-prefix $S3_PREFIX"
      fi
      aws cloudformation deploy --stack-name ${STACK_NAME} ${TEMPLATE_PATH} \
        --parameter-overrides \
          StackEnv=${STACK_ENV} \
          StackJobName=${STACK_JOB_ENV} \
          StackTier=${STACK_TIER} \
          StackType=${ACCOUNT_LEVEL} \
          StackVersion=${STACK_VERSION_RELEASE} \
          StackVersionSha=${CI_COMMIT_SHA} \
          StackVersionType=${STACK_TARGETED_VERSION} \
          VpcEdgeProxyInternalElbListenerArn="/pf-vpcedge-${STACK_ENV_TYPE}/resources/elb/listener/proxy-internal/arn" \
          VpcEdgeProxyPublicElbListenerArn="/pf-vpcedge-${STACK_ENV_TYPE}/resources/elb/listener/proxy-public/arn" \
          "${@:3}" \
        --tags \
          service_name=${STACK_SERVICE_NAME} \
          service_env=${STACK_ENV} \
          service_tier=${STACK_TIER} \
