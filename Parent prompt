            PROJECT_RUNTIME="Dotnet"
          elif [[ ! -z ${NODE_REPO} ]];then
            PROJECT_RUNTIME="Nodejs"
          elif [[ ! -z ${PYTHON_REPO} ]];then
            PROJECT_RUNTIME="Python"
          else
            PROJECT_RUNTIME="Unknown"
          fi
          if grep -qE "AWS::ECS::Service" "aws.cfn.app.yml" && grep -qE "AWS::Serverless::Api|AWS::Serverless::Function" "aws.cfn.app.yml";then
            PROJECT_AWS_PLATFORM="ECS and Serverless"
